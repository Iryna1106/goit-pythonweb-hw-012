[run]
branch = True
source = src,main
omit =
    src/__init__.py
    src/*/__init__.py
    tests/*

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == "__main__":
    \.\.\. *$
show_missing = True
skip_covered = False
precision = 1

[html]
directory = htmlcov

[xml]
output = coverage.xml
